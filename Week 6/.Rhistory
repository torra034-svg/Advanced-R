make_labels <- function(x, values, labels) {
if(length(values) != length(labels)) {
stop("The 'values' and 'labels' vectors must have the same length.") }
if(any(!(x %in% values))) {
warning("There are values in 'x' that do not appear in 'values'. These will appear as NA in the output.") }
factor(x, levels = values, labels = labels)
}
