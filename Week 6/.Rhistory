#| eval: false
#MODIFY
label_all_from_dict <- function(data, dict) {
cat_vars <- dict %>%
filter(type == "categorical") %>%
distinct(variable) %>%
pull(variable)
M <- map_dfc(cat_vars, .f = label_from_dict, data = data, dict = dict)
colnames(M) <- cat_vars
full_data <- M %>%
bind_cols(data %>% dplyr::select(-all_of(cat_vars))) %>%
select(all_of(colnames(data)))
return(full_data)
}
labeled_df <- atus %>% label_all_from_dict(atus_dict)
