label_from_dict <- function(v_name, data, dict) {
if(!(v_name %in% names(data))) {
stop(paste(v_name, " not found in the data frame."))
}
if(!(v_name %in% atus_dict$variable)) {
stop(paste(v_name, " not found in the dictionary."))
}
v_dict <- dict[atus_dict$variable == v_name]
if(nrow(v_dict) <= 1) {
stop(paste(v_name, "is not categorical variable"))
}
raw_numbers <- data[[v_name]]
make_labels(x = raw_numbers,
values = v_dict$value,
labels = v_dict$label)
}
