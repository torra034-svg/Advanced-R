# Chunk 1: load atus_functions + data
source("atus_functions.R")
atus <- read.csv("atus_raw-1.csv")
# Chunk 2: library
library(tidyverse)
library(showtext) # for ggplot
showtext_auto()
library(gtsummary) # for table
library(gtable)
# Chunk 3: data cleaning
sleep <- atus %>%
select(AGE, ACT_SLEEPING) %>%
mutate(age_group = case_when(AGE < 18 ~ "1-17",
AGE >= 18 & AGE < 25 ~ "18-24",
AGE >= 25 & AGE < 40 ~ "25-39",
AGE >= 39 & AGE < 60 ~ "40-59",
AGE >= 60 & AGE < 80 ~ "60-79",
AGE >= 80 & AGE < 100 ~ "80-100",
.default = "100+"),
sleep_hours = round(ACT_SLEEPING / 60,1)) %>%
group_by(age_group) %>%
summarize(avg_sleep_hours = round(mean(sleep_hours, na.rm = TRUE),1),
median_sleep_hours = round(median(sleep_hours, na.rm = TRUE),1),
st.dev_sleep_hours = round(sd(sleep_hours, na.rm = TRUE),1))
# Chunk 4: sleep table
sleep %>%
gt() %>%
cols_label(
age_group = "Age Group",
avg_sleep_hours = "Average",
median_sleep_hours = "Median",
st.dev_sleep_hours = "SD"
) %>%
tab_header(title = "Daily Sleep Summary") %>%
gfmt_number(columns = 2:4, decimals = 1) %>% # Keeps decimals consistent
cols_align(align = "center", columns = 2:4)
