sleep <- atus %>%
select(AGE, ACT_SLEEPING) %>%
mutate(age_group = factor(case_when(AGE < 18 ~ "1-17",
AGE >= 18 & AGE < 25 ~ "18-24",
AGE >= 25 & AGE < 40 ~ "25-39",
AGE >= 39 & AGE < 60 ~ "40-59",
AGE >= 60 & AGE < 80 ~ "60-79",
AGE >= 80 & AGE < 100 ~ "80-100",
.default = "100+"),
levels = c("1-17", "18-24", "25-39", "40-59", "60-79", "80-100")) %>%
sleep_hours = round(ACT_SLEEPING / 60,1)) %>%
sleep <- atus %>%
select(AGE, ACT_SLEEPING) %>%
mutate(age_group = case_when(AGE < 18 ~ "1-17",
AGE >= 18 & AGE < 25 ~ "18-24",
AGE >= 25 & AGE < 40 ~ "25-39",
AGE >= 39 & AGE < 60 ~ "40-59",
AGE >= 60 & AGE < 80 ~ "60-79",
AGE >= 80 & AGE < 100 ~ "80-100",
.default = "100+"),
age_group = fct_relevel(age_group, c("1-17", "18-24", "25-39", "40-59", "60-79", "80-100")),
sleep_hours = round(ACT_SLEEPING / 60,1)) %>%
group_by(age_group) %>%
summarize(avg_sleep_hours = round(mean(sleep_hours, na.rm = TRUE),1))
