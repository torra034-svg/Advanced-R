# Chunk 4: sleep table
sleep %>%
gt() %>%
cols_label(
age_group = "Age Group",
avg_sleep_hours = "Average",
median_sleep_hours = "Median",
st.dev_sleep_hours = "SD"
) %>%
tab_header(title = "Daily Sleep Summary") %>%
fmt_number(columns = 2:4, decimals = 1) %>% # Keeps decimals consistent
cols_align(align = "center", columns = 2:4)
# Chunk 5: sleep visualization
ggplot(sleep, aes(x = age_group, y = avg_sleep_hours, fill = age_group)) +
geom_col() +
geom_text(aes(label = round(avg_sleep_hours, 1)),
hjust = -1.2,
color = "black",
fontface = "bold") +
labs(x = NULL,
y = "Average Sleep",
fill = "Age Group",
title = "Average Sleep (Hours) by Age Group") +
coord_flip() +
theme_minimal(base_family = "Verdana") +
theme(axis.title.x = element_blank(),
axis.ticks.length.x = unit(0, "cm"),
axis.text.x = element_blank(),
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
legend.position = "none")
