# Chunk 1: load-packages
library(tidyverse)
library(dsbox)
library(scales)
# Chunk 2: import data
data("lego_sales")
# Chunk 3: first name
lego_sales %>%
group_by(first_name) %>%
summarize(first_name_count = n()) %>%
slice_max(n =3, order_by = first_name_count, with_ties = TRUE)
# Chunk 4: lego theme
lego_sales %>%
group_by(theme) %>%
summarize(lego_theme_count = n()) %>%
slice_max(n = 3, order_by = lego_theme_count, with_ties = TRUE)
# Chunk 5: common subtheme
lego_sales %>%
filter(theme == "Star Wars") %>%
group_by(subtheme) %>%
summarize(subtheme_count = n()) %>%
slice_max(n = 1, order_by = subtheme_count, with_ties = TRUE)
# Chunk 6: age_group variable
lego_sales <- lego_sales %>%
mutate(age_group = case_when(
age <= 18 ~ "18 and under",
age %in% 19:25 ~ "19-25",
age %in% 26:35 ~ "26-35",
age %in% 36:50 ~ "36-50",
age >= 51 ~ "51 and over"
))
# Chunk 7: age group purchase
lego_sales %>%
group_by(age_group) %>%
summarize(purchase_quantity = sum(quantity)) %>%
slice_max(n=1, order_by = purchase_quantity)
# Chunk 8: age group purchase most on Legos
age_group_money <- lego_sales %>%
group_by(age_group, us_price) %>%
summarize(purchase_quantity = sum(quantity)) %>%
mutate(collective_spending = us_price * purchase_quantity)
age_group_money
# Chunk 9: age group money final aggregation
age_group_money %>%
group_by(age_group) %>%
summarize(money_spent_on_legos = sum(collective_spending))
# Chunk 10: most money based on lego theme
lego_theme_sales <- lego_sales %>%
group_by(theme, us_price) %>%
summarize(purchase_quantity = sum(quantity)) %>%
mutate(individual_theme_price = us_price * purchase_quantity)
lego_theme_sales
# Chunk 11: theme aggregation calculation
lego_theme_sales_aggregate <- lego_theme_sales %>%
group_by(theme) %>%
summarize(aggregate_theme_price = sum(individual_theme_price))
view(lego_theme_sales_aggregate) #need to do sanity check
# Chunk 12: lego_theme_sales_aggregate slice_max
lego_theme_sales_aggregate %>%
slice_max(n = 1, order_by = aggregate_theme_price)
# Chunk 13: area code variable
lego_sales <- lego_sales %>%
mutate(area_code = str_sub(string = phone_number,
start = 1,
end = 3))
# Chunk 14: area code spending habits
lego_sales_by_area_code <- lego_sales %>%
group_by(area_code, us_price) %>%
summarize(purchase_quantity = sum(quantity)) %>%
mutate(aggregate_individual_product_purchase = us_price * purchase_quantity)
view(lego_sales_by_area_code) #need to do sanity check
# Chunk 15: area code aggregation
area_code_aggregation <- lego_sales_by_area_code %>%
group_by(area_code) %>%
summarize(aggregate_sum_calculation =
sum(aggregate_individual_product_purchase))
view(area_code_aggregation) #another sanity check
# Chunk 16: arrange area code by slice max
area_code_aggregation %>%
slice_max(n = 2, order_by = aggregate_sum_calculation)
# Chunk 17: 51+ popular themes calculation
"51_plus" <- lego_sales %>%
filter(age_group == "51 and over") %>%
group_by(theme, name, pieces) %>%
summarize(theme_count = n(),
.groups = "drop") %>%
slice_max(order_by = theme_count, n = 3)
view(`51_plus`)
