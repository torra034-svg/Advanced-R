slice_max(order_by = theme_count, n = 3)
view(`51_plus`)
"51_plus" <- lego_sales %>%
filter(age_group == "51 and over") %>%
group_by(theme, pieces) %>%
summarize(total_sales = n(),
total_pieces = sum(pieces, na.rm = TRUE),
.groups = "drop") %>%
slice_max(order_by = theme_count, n = 3)
"51_plus" <- lego_sales %>%
filter(age_group == "51 and over") %>%
group_by(theme, pieces) %>%
summarize(total_sales = n(),
total_pieces = sum(pieces, na.rm = TRUE),
.groups = "drop") %>%
slice_max(order_by = total_sales, n = 3)
view(`51_plus`)
"51_plus" <- lego_sales %>%
filter(age_group == "51 and over") %>%
group_by(theme, pieces) %>%
summarize(total_sales = n(),
total_pieces = sum(pieces, na.rm = TRUE),
.groups = "drop") %>%
slice_max(order_by = total_sales, n = 3, with_ties = TRUE) %>%
arrange(desc(total_sales), desc(total_pieces))
