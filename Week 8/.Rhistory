area_code_aggregation <- lego_sales_by_area_code %>%
group_by(area_code) %>%
summarize(aggregate_sum_calculation =
sum(aggregate_individual_product_purchase))
view(area_code_aggregation) #another sanity check
# Chunk 16: arrange area code by slice max
area_code_aggregation %>%
slice_max(n = 2, order_by = aggregate_sum_calculation)
