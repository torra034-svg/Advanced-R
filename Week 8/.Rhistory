options(tigris_use_cache = TRUE) # this caches data so it doesn't request API repeatedly
#Call the ACS API, returns a sf object
mn_income.df <- get_acs(
geography = "tract",
variables = "B19013_001", #Code for median income
state     = "MN",
county    = "Hennepin",
year      = 2020,
geometry  = TRUE,
cb        = FALSE
)
head(mn_income.df)
mn_income_plotly.df <- mn_income.df %>%
mutate(
tract      = str_split(NAME, ",") %>%
map_chr(1) %>%
str_remove("Census Tract "),
text_label = str_c(
"Tract: ",
tract,
"\nMedian Income: ",
scales::dollar(estimate)
)
)
# Building plot
income.gg <- ggplot() +
geom_sf(data = mn_income_plotly.df, aes(fill = estimate, text = text_label)) +
labs(title = "Hennepin County 2020 ACS Estimated Median Income") +
theme_void() +
scale_fill_viridis_c("Median Income", option = "C", labels = scales::dollar)
income.gg
ggplotly(income.gg,
tooltip = "text",
height  = 600,
width   = 800) %>%
style(hoveron = "fills")
